# AI Team Hub — Environment Variables
# Copy to .env and fill in values

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///data/ai_team_hub.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/ai_team_hub

# ── Server ──
WORKER_ENV=production
LOG_LEVEL=info
PORT=8910

# ── Encryption (REQUIRED for production) ──
# Fernet key for encrypting sensitive data (API keys, etc.) stored in DB.
# Generate one: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, a key is auto-generated on first run and saved to data/.crypto_key
AI_TEAM_HUB_CRYPTO_KEY=

# ── API Keys (legacy /api/* routes — optional) ──
# These are stored encryoted in the DB, but you can seed initial keys via env:
# OPENROUTER_API_KEY=cfut_...

# ── CORS ──
# Comma-separated list of allowed origins. When SET, credentials are enabled
# and these exact origins are allowed. When UNSET, CORS is open ("*") with
# credentials disabled (valid dev mode).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Admin Key (sensitive endpoint protection) ──
# When SET, all sensitive management endpoints (/api/apikeys, teammate/channel
# mutations, /api/workspaces, semantic-cache writes) require:
#   Authorization: Bearer <key>   OR   X-Admin-Key: <key>
# When UNSET, those endpoints remain OPEN (legacy dev behavior).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
AI_TEAM_HUB_ADMIN_KEY=

# ── Model Defaults ──
DEFAULT_PROVIDER=openrouter
DEFAULT_MODEL=openrouter/owl-alpha
